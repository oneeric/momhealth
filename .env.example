# Upstash Redis（雲端共享資料）
# Vercel 整合會注入 KV_REST_API_URL、KV_REST_API_TOKEN
# 本地開發可從 Upstash Console 複製（任一組即可）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# 或 Vercel 整合使用的名稱：
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# LINE 提醒 Cron 保護（選用，建議設定）
# CRON_SECRET=

# LINE Messaging API
# 從 LINE Developers Console 取得
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
